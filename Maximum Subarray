class Solution:
    def maxSubArray(self, nums: List[int]) -> int:
        curr_sum=0
        max_sum=float('-inf')
        # if len(nums)==1:
            # return nums[0]
        for i in range(len(nums)):
            curr_sum+=nums[i]
            if curr_sum<0:
                curr_sum=0
            else:
                max_sum=max(max_sum,curr_sum)
        return max_sum
